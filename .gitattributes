# Normalize line endings: store text as LF, check out as LF on every platform.
# Silences the "LF will be replaced by CRLF" warnings and keeps diffs clean.
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
*.pdf  binary
