# Copy this file to ".env"  (NOT .env.local — Prisma's CLI reads .env)
# then fill in real values and restart:  npm run dev
# Everything is optional: unset/placeholder values just disable that feature
# (checkout → demo mode, DB → not persisted, email → logged to console).

# ── Database (local PostgreSQL) ─────────────────────────────────────────────
# Create a db first, e.g.:  createdb hariprabodham   (or via pgAdmin)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hariprabodham?schema=public

# ── Razorpay (server-side only — the secret never reaches the browser) ──────
# Dashboard → Settings → API Keys. Use rzp_test_… while testing.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret (Dashboard → Settings → Webhooks). DIFFERENT from the key secret.
# Subscribe the endpoint /api/razorpay/webhook to: payment.captured, order.paid
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXX

# ── Email (SMTP via Nodemailer) ─────────────────────────────────────────────
# Any SMTP works (Gmail app password, Zoho, your host's mail server, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false           # true for port 465, false for 587/STARTTLS
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password
MAIL_FROM=Hariprabodham Sweets <orders@example.com>
SHOP_EMAIL=                 # optional: BCC every confirmation here for your own tracking
